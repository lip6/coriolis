liberty = shared_library (
  'liberty',
  'AnonymousGroup.cpp',
  'Attribute.cpp',
  'ComplexGroup.cpp',
  'ComplexValue.cpp',
  'Define.cpp',
  'Group.cpp',
  'Library.cpp',
  'LibertyLibProperty.cpp',
  'LibertyProperty.cpp',
  'Parser.cpp',
  'Reader.cpp',
  'SimpleGroup.cpp',
  'Statement.cpp',
  'Tokenizer.cpp',
  'Value.cpp',
  'ValueString.cpp',
  include_directories: crlcore_includes,
  link_with: [crlcore,hurricane],
  dependencies: Hurricane,
  install: true,
)
